# BimaGrid USSD service — copy to .env
# cp .env.example .env

USSD_SECRET_KEY=ussd-dev-secret-key-change-in-production
USSD_DEBUG=True
USSD_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
USSD_VERSION=1.0.0
USSD_LOG_LEVEL=INFO
TIME_ZONE=Africa/Nairobi

# Django backend (internal APIs)
BACKEND_URL=http://localhost:8000
USSD_INTERNAL_API_KEY=bimagrid-ussd-internal-dev-key
BACKEND_TIMEOUT_SECONDS=10.0

# Africa's Talking
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_API_KEY=
AFRICASTALKING_VERIFY_SIGNATURE=False

# Session store (optional — falls back to in-memory)
REDIS_URL=
SESSION_TTL=180
USE_IN_MEMORY_SESSIONS=True

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
