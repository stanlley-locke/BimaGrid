# BimaGrid — copy to .env and fill in values
# cp .env.example .env

# Core
SECRET_KEY=change-me-in-production
DEBUG=True
BIMAGRID_VERSION=1.0.0
DJANGO_LOG_LEVEL=INFO
LANGUAGE_CODE=en-us
TIME_ZONE=Africa/Nairobi

# Database (defaults to SQLite when unset)
DATABASE_ENGINE=django.db.backends.sqlite3
DATABASE_NAME=db.sqlite3
# For PostgreSQL via Docker:
# DATABASE_ENGINE=django.db.backends.postgresql
# DATABASE_NAME=bimagrid
# DATABASE_USER=bimagrid
# DATABASE_PASSWORD=bimagrid
# DATABASE_HOST=localhost
# DATABASE_PORT=5432

# Celery / Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_ALWAYS_EAGER=True

# Email
DEFAULT_FROM_EMAIL=noreply@bimagrid.io

# M-Pesa Daraja
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=174379
MPESA_PASSKEY=
MPESA_INITIATOR_NAME=BimaGridAdmin
MPESA_SECURITY_CREDENTIAL=
MPESA_B2C_SHORTCODE=600123
MPESA_CALLBACK_BASE_URL=http://localhost:8000
MPESA_ENVIRONMENT=sandbox
MPESA_USE_MOCK=True

# Africa's Talking (SMS / USSD)
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_API_KEY=
AFRICASTALKING_SENDER_ID=BimaGrid
AFRICASTALKING_USE_MOCK=True

# Standalone USSD service
USSD_SERVICE_URL=http://localhost:8001
USSD_INTERNAL_API_KEY=bimagrid-ussd-internal-dev-key
USSD_DEBUG=True
BACKEND_URL=http://localhost:8000
REDIS_URL=redis://localhost:6379/2

# openEO (satellite analytics)
OPENEO_BACKEND_URL=https://earthengine.openeo.org
OPENEO_USERNAME=
OPENEO_PASSWORD=
OPENEO_USE_MOCK=True

# Government identity / land registry
IPRS_API_URL=https://iprs.go.ke/api/v1
IPRS_API_KEY=
IPRS_USE_MOCK=True
ARDHISASA_API_URL=https://ardhisasa.lands.go.ke/api/v1
ARDHISASA_CLIENT_ID=
ARDHISASA_CLIENT_SECRET=
ARDHISASA_USE_MOCK=True

# Oracle / blockchain
BLOCKCHAIN_RPC_URL=http://localhost:8545
ORACLE_SIGNATURE_VERIFY=False
ORACLE_AUTHORIZED_KEYS=

# Geospatial
H3_DEFAULT_RESOLUTION=9

# API rate limiting
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60

# USSD (standalone service on port 8001 — optional proxy)
USSD_SERVICE_URL=http://localhost:8001
USSD_SERVICE_TIMEOUT=10.0
USSD_INTERNAL_API_KEY=bimagrid-ussd-internal-dev-key
