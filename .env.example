
# BimaGrid — Complete Environment Configuration
# Copy this file: cp .env.example .env
# Fill in all values marked with <CHANGE_ME> before deploying


# ────────────────────────────────────────────────────────────
# CORE DJANGO
# ────────────────────────────────────────────────────────────
SECRET_KEY=e3412g525453bb635y45gy54yyb4523g6563g56tgy5463624w3gt3g434t66
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend,nginx,api-gateway
DJANGO_SETTINGS_MODULE=config.settings.development
BIMAGRID_VERSION=1.0.0
DJANGO_LOG_LEVEL=INFO
LANGUAGE_CODE=en-us
TIME_ZONE=Africa/Nairobi
USE_TZ=True
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:3000,http://localhost:3001
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ────────────────────────────────────────────────────────────
# DATABASE (PostgreSQL)
# ────────────────────────────────────────────────────────────
DATABASE_ENGINE=django.db.backends.postgresql
DATABASE_NAME=bimagrid
DATABASE_USER=bimagrid
DATABASE_PASSWORD=bimagrid2026
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_CONN_MAX_AGE=60

# Docker Compose Postgres variables
POSTGRES_DB=bimagrid
POSTGRES_USER=bimagrid
POSTGRES_PASSWORD=bimagrid2026

# SQLite fallback for quick local dev (comment out Postgres above):
# DATABASE_ENGINE=django.db.backends.sqlite3
# DATABASE_NAME=db.sqlite3

# ────────────────────────────────────────────────────────────
# REDIS
# ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CACHE_URL=redis://localhost:6379/3
SESSION_CACHE_URL=redis://localhost:6379/4

# ────────────────────────────────────────────────────────────
# CELERY (Async Task Queue)
# ────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_ALWAYS_EAGER=False
CELERY_TASK_EAGER_PROPAGATES=True
CELERY_ACCEPT_CONTENT=application/json
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_TIMEZONE=Africa/Nairobi

# ────────────────────────────────────────────────────────────
# M-PESA DARAJA API
# ────────────────────────────────────────────────────────────
MPESA_CONSUMER_KEY=<CHANGE_ME_from_safaricom_developer_portal>
MPESA_CONSUMER_SECRET=<CHANGE_ME_from_safaricom_developer_portal>
MPESA_SHORTCODE=174379
MPESA_PASSKEY=<CHANGE_ME_from_safaricom_developer_portal>
MPESA_INITIATOR_NAME=BimaGridAdmin
MPESA_SECURITY_CREDENTIAL=<CHANGE_ME_base64_encoded_openssl_encrypted>
MPESA_B2C_SHORTCODE=600123
MPESA_CALLBACK_BASE_URL=https://api.bimagrid.io
MPESA_ENVIRONMENT=sandbox
# Set to False in production
MPESA_USE_MOCK=True

# ────────────────────────────────────────────────────────────
# AFRICA'S TALKING (SMS + USSD)
# ────────────────────────────────────────────────────────────
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_API_KEY=<CHANGE_ME_from_africastalking_dashboard>
AFRICASTALKING_SENDER_ID=BimaGrid
AFRICASTALKING_VERIFY_SIGNATURE=False
# Set to False in production
AFRICASTALKING_USE_MOCK=True

# ────────────────────────────────────────────────────────────
# STANDALONE USSD MICROSERVICE
# ────────────────────────────────────────────────────────────
# In production: http://ussd:8001 (Docker internal)
BACKEND_URL=http://localhost:8000
BACKEND_API_KEY=bimagrid-ussd-internal-dev-key
BACKEND_TIMEOUT_SECONDS=10.0

# gRPC backend target for USSD→Backend RPC calls
GRPC_BACKEND_TARGET=localhost:50051

# USSD-specific Django settings
USSD_DEBUG=True
USSD_SECRET_KEY=<CHANGE_ME_ussd_service_secret>
USSD_ALLOWED_HOSTS=localhost,127.0.0.1,ussd
USSD_REDIS_URL=redis://localhost:6379/2

# ────────────────────────────────────────────────────────────
# GRPC SERVER (Django Backend)
# ────────────────────────────────────────────────────────────
GRPC_PORT=50051
GRPC_MAX_WORKERS=10

# ────────────────────────────────────────────────────────────
# API GATEWAY (Node.js/Express)
# ────────────────────────────────────────────────────────────
# In Docker: http://backend:8000, http://ussd:8001
GATEWAY_PORT=3001
GATEWAY_BACKEND_URL=http://localhost:8000
GATEWAY_USSD_URL=http://localhost:8001
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
LOG_LEVEL=info
NODE_ENV=development

# ────────────────────────────────────────────────────────────
# ORACLE NODE (Rust)
# ────────────────────────────────────────────────────────────
# Oracle node private key (secp256k1 — NEVER commit a real key)
ORACLE_SIGNING_KEY=0x47e175b104810481048104810481048104810481048104810481048104810481
ORACLE_NODE_ID=oracle-1
ORACLE_DATA_SOURCES=open-meteo,nasa-power,chirps

# gRPC endpoint for Oracle→Backend submissions
BACKEND_GRPC_URL=http://localhost:50051

# Authorized oracle public keys (comma-separated, for on-chain whitelist)
ORACLE_AUTHORIZED_KEYS=

# Django backend verification
ORACLE_SIGNATURE_VERIFY=False

# ────────────────────────────────────────────────────────────
# BLOCKCHAIN / SMART CONTRACTS
# ────────────────────────────────────────────────────────────
# Local Hardhat node (dev), or Alchemy/Infura URL for production
BLOCKCHAIN_RPC_URL=http://localhost:8545

# Deployed contract addresses (filled in after deployment)
CONTRACT_KILIMA_SHIELD_ORACLE=0x0000000000000000000000000000000000000000
CONTRACT_POLICY_REGISTRY=0x0000000000000000000000000000000000000000
CONTRACT_ESCROW_VAULT=0x0000000000000000000000000000000000000000
CONTRACT_MITIGATION_VERIFIER=0x0000000000000000000000000000000000000000

# Hardhat deployer private key (only for local dev!)
HARDHAT_DEPLOYER_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Chain ID: 31337 = Hardhat local, 137 = Polygon, 1 = Ethereum mainnet
CHAIN_ID=31337

# ────────────────────────────────────────────────────────────
# SATELLITE DATA SOURCES
# ────────────────────────────────────────────────────────────
# openEO (NDVI/EVI computation via ESA/Google Earth Engine backend)
OPENEO_BACKEND_URL=https://earthengine.openeo.org
OPENEO_USERNAME=<CHANGE_ME>
OPENEO_PASSWORD=<CHANGE_ME>
OPENEO_USE_MOCK=True

# NASA POWER (rainfall, temperature) — public API, no key required
# CHIRPS (precipitation) — public API

# ────────────────────────────────────────────────────────────
# GEOSPATIAL
# ────────────────────────────────────────────────────────────
H3_DEFAULT_RESOLUTION=9

# ────────────────────────────────────────────────────────────
# KENYA GOVERNMENT INTEGRATIONS
# ────────────────────────────────────────────────────────────
# IPRS — Kenya National Identity Verification
IPRS_API_URL=https://iprs.go.ke/api/v1
IPRS_API_KEY=<CHANGE_ME>
IPRS_USE_MOCK=True

# ArdhiSasa — Kenya Land Registry
ARDHISASA_API_URL=https://ardhisasa.lands.go.ke/api/v1
ARDHISASA_CLIENT_ID=<CHANGE_ME>
ARDHISASA_CLIENT_SECRET=<CHANGE_ME>
ARDHISASA_USE_MOCK=True

# ────────────────────────────────────────────────────────────
# EMAIL (Django)
# ────────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@bimagrid.io
# Production SMTP:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=apikey
# EMAIL_HOST_PASSWORD=<CHANGE_ME_sendgrid_api_key>

# ────────────────────────────────────────────────────────────
# SECURITY (Production)
# ────────────────────────────────────────────────────────────
# Set True in production only
SECURE_HSTS_SECONDS=0
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# JWT Token lifetimes
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Internal service-to-service API key
INTERNAL_API_KEY=bimagrid-internal-dev-key-change-in-prod

# ────────────────────────────────────────────────────────────
# MONITORING (Optional)
# ────────────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
DATADOG_API_KEY=

# ────────────────────────────────────────────────────────────
# FRONTEND (Next.js)
# ────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_CHAIN_ID=31337
NEXT_PUBLIC_ORACLE_CONTRACT=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_POLICY_REGISTRY=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_ESCROW_VAULT=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/
